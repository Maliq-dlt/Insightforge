APP_ENV=development
DATABASE_URL=./.runtime/data/insightforge.db
ARTIFACT_DIR=./.runtime/artifacts
DATASET_DIR=./.runtime/datasets
TEMP_DIR=./.runtime/tmp
BENCHMARK_REPORT_DIR=./.runtime/benchmark/reports
MAX_UPLOAD_MB=100
SQL_TIMEOUT_SECONDS=30
SQL_MEMORY_LIMIT_MB=512
SQL_MAX_ROWS=500
MAX_RETRIES=1

LLM_PROVIDER=deterministic
LLM_MODEL=gpt-5-mini
OPENAI_API_KEY=

PYTHON_SANDBOX_IMAGE=insightforge:latest
PYTHON_TIMEOUT_SECONDS=30
PYTHON_MEMORY_LIMIT_MB=1024
PYTHON_MAX_OUTPUT_KB=512

MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=sqlite:///./.runtime/data/mlflow.db
MLFLOW_EXPERIMENT=insightforge

AUTH_ENABLED=false
AUTH_BOOTSTRAP_USERNAME=
AUTH_BOOTSTRAP_PASSWORD=
AUTH_TOKEN_TTL_HOURS=24
